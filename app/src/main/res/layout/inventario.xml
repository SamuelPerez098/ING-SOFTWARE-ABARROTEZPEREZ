<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <TextView
            android:id="@+id/tvEstadoBtInv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modo: Lector (HID)"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ID Producto (Código de Barras):"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etCodigoProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Esperando lectura de escáner..."
            android:focusable="false"
            android:cursorVisible="false"
            android:longClickable="false"
            android:background="#E0E0E0"
            android:textColor="#000000"
            android:textStyle="bold"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <AutoCompleteTextView
            android:id="@+id/actvNombre"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:completionThreshold="1"
            android:hint="Nombre del Producto (Ej. Sabritas)"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/etDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción"
            android:inputType="textMultiLine"
            android:lines="2"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPrecioVenta"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="12dp"
            android:hint="Precio de Venta ($)"
            android:inputType="numberDecimal" />

        <TextView
            android:id="@+id/tvStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:text="Cantidad en Stock: 0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="#E0E0E0" />

        <CheckBox
            android:id="@+id/cbNoPerecedero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No perecedero (Sin caducidad)"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/layoutCaducidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/etCaducidad"
                android:layout_width="match_parent"
                android:layout_height="63dp"
                android:hint="Caducidad (DD/MM/AA)"
                android:inputType="number"
                android:maxLength="8" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnLimpiar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Limpiar"
                android:textColor="#D32F2F"
                android:layout_marginEnd="8dp"
                style="?attr/materialButtonOutlinedStyle"/>

            <Button
                android:id="@+id/btnGuardarProducto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Guardar"
                android:backgroundTint="#4CAF50"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>